# Supabase (server-side)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase (client-side, used by Vite during build)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Web Push VAPID keys (generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_EMAIL=mailto:you@example.com

# HOW TO USE:
# 1. Copy this file: cp .env.example .env
# 2. Fill in your Supabase values (from supabase.com > Settings > API)
# 3. Update VAPID_EMAIL with your real email
# 4. For Netlify: paste all 7 variables into Site settings > Environment variables
